---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white" role="contentinfo">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <div>
        <h3 class="text-lg font-semibold mb-4">
          <span class="text-secondary">CPN</span> Estudio Contable
        </h3>
        <p class="text-white/70 text-sm leading-relaxed">
          Servicios contables profesionales con más de 15 años de experiencia.
          Asesoramiento personalizado para monotributistas, PyMEs y profesionales independientes.
        </p>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-3" role="list">
          <li><a href="#servicios" class="text-white/70 hover:text-secondary transition-colors text-sm">Servicios</a></li>
          <li><a href="#sobre-mi" class="text-white/70 hover:text-secondary transition-colors text-sm">Sobre Mí</a></li>
          <li><a href="#testimonios" class="text-white/70 hover:text-secondary transition-colors text-sm">Testimonios</a></li>
          <li><a href="#contacto" class="text-white/70 hover:text-secondary transition-colors text-sm">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4">Contacto</h3>
        <address class="not-italic text-white/70 text-sm space-y-3">
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contacto@cpnestudio.com" class="hover:text-secondary transition-colors">contacto@cpnestudio.com</a>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+541112345678" class="hover:text-secondary transition-colors">+54 11 1234-5678</a>
          </p>
        </address>
      </div>
    </div>

    <div class="border-t border-white/20 mt-8 pt-8 text-center text-sm text-white/50">
      <p>&copy; {currentYear} CPN Estudio Contable. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
