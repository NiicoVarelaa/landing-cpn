---
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';

const services = [
  {
    title: 'Liquidación de Impuestos',
    description: 'Ganancias, IVA, Bienes Personales, Ingresos Brutos y más.',
    icon: 'calculator',
  },
  {
    title: 'Monotributo',
    description: 'Altas, bajas, recategorización semestral y planificación fiscal.',
    icon: 'file',
  },
  {
    title: 'Sueldos y Jornales',
    description: 'Liquidación mensual, cargas sociales, F.931 y certificados.',
    icon: 'users',
  },
  {
    title: 'Asesoramiento Integral',
    description: 'Constitución de sociedades, contratos y auditoría contable.',
    icon: 'shield',
  },
];

const icons: Record<string, string> = {
  calculator: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />',
  file: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l3 2" />',
  users: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  shield: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
};
---

<section id="servicios" class="py-20 md:py-28 bg-accent/50" aria-labelledby="services-heading">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="services-heading" class="text-2xl md:text-4xl font-heading font-bold text-primary mb-4">
        Servicios Profesionales
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        Soluciones contables integrales adaptadas a las necesidades de cada cliente.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <Card class="border-border hover:-translate-y-1 hover:shadow-lg transition-all duration-300 border-t-4 border-t-transparent hover:border-t-secondary">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[service.icon]}></svg>
            </div>
            <CardTitle class="text-lg">{service.title}</CardTitle>
          </CardHeader>
          <CardContent>
            <CardDescription class="text-sm">{service.description}</CardDescription>
          </CardContent>
        </Card>
      ))}
    </div>
  </div>
</section>
