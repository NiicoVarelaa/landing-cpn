---
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Textarea } from '@/components/ui/textarea';
---

<section id="contacto" class="py-16 md:py-24" aria-labelledby="contact-heading">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="contact-heading" class="text-2xl md:text-4xl font-bold text-primary mb-4">
        Contactame
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        Completá el formulario y te respondo a la brevedad. La primera consulta es sin cargo.
      </p>
    </div>

    <form id="contact-form" class="max-w-lg mx-auto space-y-6" novalidate>
      <div class="flex flex-col gap-1.5">
        <Label for="name" class="text-foreground font-medium">
          Nombre completo <span class="text-destructive" aria-hidden="true">*</span>
        </Label>
        <Input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          placeholder="Ej: María García"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <Label for="email" class="text-foreground font-medium">
          Email <span class="text-destructive" aria-hidden="true">*</span>
        </Label>
        <Input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="maria@email.com"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <Label for="phone" class="text-foreground font-medium">
          Teléfono <span class="text-muted-foreground font-normal text-xs">(opcional)</span>
        </Label>
        <Input
          id="phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          placeholder="+54 11 1234-5678"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <Label for="message" class="text-foreground font-medium">
          Consulta <span class="text-destructive" aria-hidden="true">*</span>
        </Label>
        <Textarea
          id="message"
          name="message"
          rows={5}
          required
          placeholder="Contame brevemente qué necesitás..."
        />
      </div>

      <Button type="submit" size="lg" class="w-full">
        Enviar Consulta
      </Button>
    </form>
  </div>
</section>

<script>
  const WHATSAPP_NUMBER = '541112345678';

  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const name = form.querySelector('#name')?.value?.trim();
    const email = form.querySelector('#email')?.value?.trim();
    const phone = form.querySelector('#phone')?.value?.trim();
    const message = form.querySelector('#message')?.value?.trim();

    let text = `Hola, soy ${name}.\n\n${message}`;
    if (email) text += `\n\nEmail: ${email}`;
    if (phone) text += `\nTeléfono: ${phone}`;

    window.open(
      `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(text)}`,
      '_blank',
      'noopener,noreferrer'
    );
  });
</script>
