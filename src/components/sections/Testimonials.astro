---
const testimonials = [
  {
    name: 'María García',
    role: 'Monotributista - Diseñadora Gráfica',
    text: 'Excelente atención. Me ayudó a organizar toda mi situación impositiva y a entender cada paso del proceso. Muy recomendable.',
  },
  {
    name: 'Carlos López',
    role: 'PyME - Director Comercial',
    text: 'Profesionalismo y claridad en cada consulta. Nos acompañó en el crecimiento de la empresa con un asesoramiento impecable.',
  },
  {
    name: 'Ana Rodríguez',
    role: 'Profesional Independiente',
    text: 'Desde que trabajo con ella, no tengo más preocupaciones con mis impuestos. Siempre disponible y con respuestas concretas.',
  },
];

const avatarColors = ['bg-primary', 'bg-secondary', 'bg-primary-light'];
---

<section id="testimonios" class="py-16 md:py-24 bg-accent/50" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="testimonials-heading" class="text-2xl md:text-4xl font-bold text-primary mb-4">
        Lo que dicen mis clientes
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        La confianza de quienes ya trabajaron conmigo es mi mejor carta de presentación.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <blockquote class="bg-background p-6 rounded-lg border border-border flex flex-col">
          <div class="flex items-center gap-4 mb-6">
            <div class={`w-12 h-12 rounded-full ${avatarColors[i]} flex items-center justify-center text-white font-bold text-lg flex-shrink-0`} aria-hidden="true">
              {t.name.charAt(0)}
            </div>
            <div>
              <cite class="not-italic font-semibold text-primary text-sm">{t.name}</cite>
              <span class="text-xs text-muted-foreground block mt-0.5">{t.role}</span>
            </div>
          </div>

          <svg class="w-8 h-8 text-secondary/30 mb-3 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          <p class="text-foreground/80 text-sm leading-relaxed flex-1 mb-6">
            {t.text}
          </p>

          <div class="flex gap-0.5" aria-label="5 estrellas">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </blockquote>
      ))}
    </div>
  </div>
</section>
