---
const testimonials = [
  {
    name: 'María García',
    role: 'Monotributista - Diseñadora Gráfica',
    text: 'Excelente atención. Me ayudó a organizar toda mi situación impositiva y a entender cada paso del proceso. Muy recomendable.',
  },
  {
    name: 'Carlos López',
    role: 'PyME - Director Comercial',
    text: 'Profesionalismo y claridad en cada consulta. Nos acompañó en el crecimiento de la empresa con un asesoramiento impecable.',
  },
  {
    name: 'Ana Rodríguez',
    role: 'Profesional Independiente',
    text: 'Desde que trabajo con ella, no tengo más preocupaciones con mis impuestos. Siempre disponible y con respuestas concretas.',
  },
];
---

<section id="testimonios" class="py-16 md:py-24 bg-accent/50" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="testimonials-heading" class="text-2xl md:text-4xl font-bold text-primary mb-4">
        Lo que dicen mis clientes
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        La confianza de quienes ya trabajaron conmigo es mi mejor carta de presentación.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <blockquote class="bg-background p-6 rounded-lg border border-border flex flex-col">
          <svg class="w-8 h-8 text-secondary/40 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-foreground/80 text-sm leading-relaxed flex-1 mb-6">
            {t.text}
          </p>
          <footer>
            <cite class="not-italic font-semibold text-primary text-sm">{t.name}</cite>
            <span class="text-xs text-muted-foreground block mt-0.5">{t.role}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
