---
const highlights = [
  'Matrícula CPA vigente',
  '+500 clientes asesorados',
  'Atención personalizada',
  'Más de 15 años de experiencia',
];
---

<section id="sobre-mi" class="py-20 md:py-28" aria-labelledby="about-heading">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <h2 id="about-heading" class="text-2xl md:text-4xl font-heading font-bold text-primary mb-6">
          Sobre Mí
        </h2>
        <div class="space-y-4 text-muted-foreground leading-relaxed">
          <p>
            Contadora Pública Nacional matriculada con más de 15 años de experiencia
            en asesoramiento contable e impositivo.
          </p>
          <p>
            Especializada en monotributo, PyMEs y profesionales independientes.
            Mi compromiso es brindar un servicio transparente, eficiente y orientado
            a resultados.
          </p>
        </div>
        <ul class="mt-8 space-y-3" role="list">
          {highlights.map((item) => (
            <li class="flex items-center gap-3 text-sm font-medium">
              <span class="w-5 h-5 flex-shrink-0 text-secondary" aria-hidden="true">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="aspect-square max-w-md mx-auto md:mx-0 bg-gradient-to-br from-primary to-primary-dark rounded-lg flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
          <svg class="w-full h-full" viewBox="0 0 400 400" fill="currentColor">
            <circle cx="200" cy="200" r="180" />
            <circle cx="200" cy="200" r="120" />
            <circle cx="200" cy="200" r="60" />
          </svg>
        </div>
        <div class="text-center">
          <div class="w-24 h-24 rounded-full bg-secondary/20 border-2 border-secondary/40 flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-heading font-bold text-secondary">CPN</span>
          </div>
          <p class="text-white/60 text-sm">Contadora Pública Nacional</p>
        </div>
      </div>
    </div>
  </div>
</section>
