---
const highlights = [
  'Matrícula CPA vigente',
  '+500 clientes asesorados',
  'Atención personalizada',
  'Más de 15 años de experiencia',
];
---

<section id="sobre-mi" class="py-16 md:py-24" aria-labelledby="about-heading">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <h2 id="about-heading" class="text-2xl md:text-4xl font-bold text-primary mb-6">
          Sobre Mí
        </h2>
        <div class="space-y-4 text-muted-foreground leading-relaxed">
          <p>
            Contadora Pública Nacional matriculada con más de 15 años de experiencia
            en asesoramiento contable e impositivo.
          </p>
          <p>
            Especializada en monotributo, PyMEs y profesionales independientes.
            Mi compromiso es brindar un servicio transparente, eficiente y orientado
            a resultados.
          </p>
        </div>
        <ul class="mt-8 space-y-3" role="list">
          {highlights.map((item) => (
            <li class="flex items-center gap-3 text-sm font-medium">
              <span class="w-5 h-5 flex-shrink-0 text-secondary" aria-hidden="true">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="aspect-square max-w-md mx-auto md:mx-0 bg-accent rounded-lg flex items-center justify-center">
        <div class="text-center text-muted-foreground">
          <svg class="w-20 h-20 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm">Foto profesional</p>
        </div>
      </div>
    </div>
  </div>
</section>
